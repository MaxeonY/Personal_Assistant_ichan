{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for app windows",
  "windows": ["pet", "wizard"],
  "permissions": [
    "default",
    "core:default",
    "opener:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-start-dragging",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "allow-set-ignore-cursor-events",
    "allow-config-get-value",
    "allow-config-set-value",
    "allow-chat-append-message",
    "allow-chat-list-by-session",
    "allow-chat-list-recent",
    "allow-workout-import-csv",
    "allow-workout-get-last-workout",
    "allow-workout-get-body-part-recency",
    "allow-first-run-complete",
    "allow-first-run-close-wizard",
    "allow-window-minimize",
    "allow-window-toggle-maximize",
    "allow-first-run-check-notion-user",
    "allow-first-run-check-notion-database",
    "allow-first-run-check-deepseek",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-hide",
    "core:window:allow-show"
  ]
}
